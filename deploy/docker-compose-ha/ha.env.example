# HA 部署差异化变量 —— 主备两端在此文件中填入不同的值，其他 .env / common.env / db.env / port.env 必须保持一致
# 复制为 ha.env 并按本节点角色填写

# 节点角色：primary | standby
export HA_ROLE=primary

# 对端节点的可达地址（IP 或域名），用于 PG 流复制、Redis/FalkorDB replicaof、NATS leafnode、MinIO Site Replication
export PEER_HOST=10.10.41.150

# 对端 PostgreSQL 端口（一般保持 5432）
export PEER_PG_PORT=5432

# 对端 NATS leafnode 端口（一般保持 7422）
export PEER_NATS_LEAFNODE_PORT=7422

# 对端 MinIO 访问地址（含协议 + 端口，主备双向需要互访）
export PEER_MINIO_ENDPOINT=http://10.10.41.150:9000

# PG 复制账号密码（主备两端必须一致；主节点会创建此账号，备节点用它来 pg_basebackup / streaming）
export PG_REPL_USER=replicator
export PG_REPL_PASSWORD=replace-me-with-strong-password

# MinIO Site Replication 使用的服务账号（首次配置 SR 时由脚本创建并复用）
export MINIO_SR_USER=sr-svc
export MINIO_SR_PASSWORD=replace-me-with-strong-password

# NATS server_name（主备必须不同；JetStream 集群唯一性要求）
export NATS_SERVER_NAME=nats-primary

# nats-executor 实例 ID（主备必须不同）
export NATS_INSTANCE_ID=primary

# 关键流名单：备节点会按此清单建立 mirror 流
# 用空格分隔；OBJ_bklite、metrics、BK_ANS_EXEC_* 等流由业务运行时动态创建，备节点会在运行时同步发现
export HA_MIRROR_STREAMS="metrics OBJ_bklite METRICS_ALL"

# Compose project 名（建议主备不同，方便审计 docker ps 输出）
export COMPOSE_PROJECT_NAME=bk-primary
